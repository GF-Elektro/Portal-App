{
  "name": "gf-elektro-portal",
  "productName": "G&F Elektro Portal",
  "version": "1.0.1",
  "description": "Desktop app for G&F Elektro Portal – Portal for managing electrical installation projects",
  "main": "src/main.js",
  "author": {
    "name": "G&F Elektro s.r.o.",
    "email": "info@gfelektro.com",
    "url": "https://www.gfelektro.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GF-Elektro/Portal-App.git"
  },
  "license": "Apache-2.0",
  "scripts": {
    "start": "electron .",
    "create-ico": "node scripts/create-ico.js",
    "make-dmg": "node scripts/build-dmg.js",
    "build": "electron-builder build"
  },
  "build": {
    "appId": "com.gfelektro.portal",
    "productName": "G&F Elektro Portal",
    "artifactName": "GFElektroPortal-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json",
      "icon-512.png",
      "build/icon.ico",
      "build/mac-tray-iconTemplate.png"
    ],
    "mac": {
      "target": ["dmg"],
      "icon": "icon-512.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "icon": "icon-512.png",
      "iconSize": 128,
      "window": {
        "width": 600,
        "height": 380
      },
      "contents": [
        {
          "x": 160,
          "y": 170,
          "type": "file"
        },
        {
          "x": 440,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "artifactName": "GFElektroPortal-${version}-Setup.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office",
      "icon": "icon-512.png"
    },
    "publish": {
      "provider": "github",
      "owner": "GF-Elektro",
      "repo": "Portal-App",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  }
}
